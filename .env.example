# ======== Database ========
# Source of truth: root .env (этот файл) для API и TypeORM CLI.
# DB_HOST правило:
# - local host run: localhost
# - docker compose (api service): postgres
# DB_PORT правило:
# - обычно 5432 и локально, и в compose (если не переопределено)
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=wooftennis
DB_USERNAME=wooftennis
DB_PASSWORD=CHANGE_ME_strong_password

# ======== JWT ========
JWT_SECRET=CHANGE_ME_random_32_char_string
JWT_EXPIRES_IN=7d

# ======== Telegram ========
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_WEBHOOK_URL=https://wooftennis.com/bot/webhook
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_random_string
TELEGRAM_MINI_APP_URL=https://wooftennis.com

# ======== Frontend (build time) ========
VITE_API_URL=https://wooftennis.com

# ======== App ========
PORT=3000
NODE_ENV=development
UPLOAD_DIR=./uploads

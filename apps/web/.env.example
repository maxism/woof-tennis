# API origin without trailing slash (browser). For local dev with Vite proxy, use empty string.
VITE_API_URL=https://alannah-hyperdemocratic-orpha.ngrok-free.dev

# Optional: JWT from POST /auth/telegram (for browser dev without Telegram)
# VITE_DEV_ACCESS_TOKEN=

# Default UI locale: ru | en
VITE_UI_LOCALE=ru

# Прямая ссылка на Mini App (кнопка «Войти через Telegram» в браузере).
# В @BotFather: Bot Settings → Configure Mini App → short name.
# Пример: https://t.me/WoofTennisBot/wooftennis
VITE_TELEGRAM_BOT_APP_URL=t.me/woof_tennis_bot/woof

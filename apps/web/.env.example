# API origin без завершающего слэша. Для локального Vite + proxy на :3000 оставьте пустым.
VITE_API_URL=

# Имя бота для Login Widget в браузере (без @). Домен страницы — через /setdomain у @BotFather.
# VITE_TELEGRAM_BOT_USERNAME=WoofTennisBot

# Только для отладки: готовый JWT (не показывать пользователям в проде).
# VITE_DEV_ACCESS_TOKEN=

# Локаль интерфейса: ru | en
VITE_UI_LOCALE=ru
